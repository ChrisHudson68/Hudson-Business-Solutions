# App
NODE_ENV=development
PORT=5555
BASE_DOMAIN=localhost
APP_URL=http://localhost:5555
APP_NAME=Hudson Business Solutions
APP_LOGO=/static/brand/hudson-business-solutions-logo.png

# Security
SECRET_KEY=replace-this-with-a-long-random-secret-key-at-least-32-characters
SESSION_TTL_SECONDS=1209600
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_BLOCK_SECONDS=900
ADMIN_AUTH_RATE_LIMIT_WINDOW_SECONDS=900
ADMIN_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
ADMIN_AUTH_RATE_LIMIT_BLOCK_SECONDS=1800
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_PASSWORD_HASH=

LAUNCH_CODE=

# Storage
DB_PATH=./data/database.db
UPLOAD_DIR=./data
MAX_UPLOAD_BYTES=5242880
MAX_LOGO_UPLOAD_BYTES=2097152
MAX_RECEIPT_UPLOAD_BYTES=5242880

# Email
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Hudson Business Solutions

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_BILLING_PORTAL_ENABLED=true
STRIPE_PRO_PLAN_LABEL=$49.00/month
STRIPE_GRACE_PERIOD_DAYS=7
